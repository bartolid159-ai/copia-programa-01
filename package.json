{
  "name": "constructor-programa-maestro",
  "version": "2.2.0",
  "description": "Local-First administrative and accounting program",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:watch": "vitest watch",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build:electron": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.clinica.medical-office",
    "productName": "Sistema de Gestión Médica",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "${productName} 32bits.${ext}",
      "requestExecutionLevel": "admin"
    },
    "asar": true,
    "npmRebuild": false,
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3",
        "to": "better-sqlite3"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "bartolid159-ai",
      "repo": "copia-programa-01"
    }
  },
  "keywords": [
    "local-first",
    "sqlite",
    "accounting",
    "erp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^5.4.21",
    "vitest": "^1.4.0",
    "wait-on": "^8.0.1"
  }
}
